{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "List(*)",
      "Fetch(*)",
      "Bash(ls:*)",
      "Bash(mv:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tar:*)",
      "Bash(gzip:*)",
      "Bash(gunzip:*)",
      "Bash(zip:*)",
      "Bash(unzip:*)",
      "Bash(ps:*)",
      "Bash(top:*)",
      "Bash(which:*)",
      "Bash(whereis:*)",
      "Bash(whoami:*)",
      "Bash(pwd:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(history:*)",
      "Bash(export:*)",
      "Bash(source:*)",
      "Bash(ln:*)",
      "Bash(touch:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(diff:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(go fmt:*)",
      "Bash(gofmt:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo clone:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr create:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh api:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(chezmoi:*)",
      "Bash(bundle:*)",
      "Read(~/.ai_agents/*)",
      "Skill(create-pr)",
      "Skill(create-pr-body)",
      "Skill(example-skills:skill-creator)",
      "mcp__devinwiki__read_wiki_contents",
      "mcp__devinwiki__ask_question"
    ],
    "deny": [
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.aws/*)",
      "Read(~/.ssh/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.kube/*)",
      "Read(~/.config/*)",
      "Read(~/.docker/config.json)",
      "Read(config/master.key)",
      "Read(config/credentials*.yml.enc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.bundle/config)",
      "Bash(cat*.env*)",
      "Bash(cat*.ssh*)",
      "Bash(cat*id_rsa*)",
      "Bash(cat*id_ed25519*)",
      "Bash(cat*.aws*)",
      "Bash(cat*credentials*)",
      "Bash(cat*master.key*)",
      "Bash(cat*.npmrc*)",
      "Bash(cat*.pypirc*)",
      "Bash(head*.env*)",
      "Bash(head*.ssh*)",
      "Bash(head*id_rsa*)",
      "Bash(head*.aws*)",
      "Bash(head*credentials*)",
      "Bash(tail*.env*)",
      "Bash(tail*.ssh*)",
      "Bash(tail*id_rsa*)",
      "Bash(tail*.aws*)",
      "Bash(tail*credentials*)",
      "Bash(less*.env*)",
      "Bash(less*.ssh*)",
      "Bash(less*id_rsa*)",
      "Bash(less*.aws*)",
      "Bash(less*credentials*)",
      "Bash(grep*.env*)",
      "Bash(grep*.ssh*)",
      "Bash(grep*id_rsa*)",
      "Bash(grep*.aws*)",
      "Bash(grep*credentials*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Codeが許可を求めています\" with title \"Claude Code\" subtitle \"確認待ち\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "wantedly-dev@wantedly-cc-plugins": true
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  }
}
